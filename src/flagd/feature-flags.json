{
  "$schema": "https://flagd.dev/schema/v0/flags.json",
  "flags": {
    "catalog_fallback_mode": {
      "description": "Fail product catalog service on a specific product",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "recommendation_cache_warmup": {
      "description": "Fail recommendation service cache",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "ad_memory_reclamation": {
      "description": "Triggers full manual garbage collections in the ad service",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "ad_personalization_burst": {
      "description": "Triggers high cpu load in the ad service",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "ad_delivery_retry_sampling": {
      "description": "Fail ad service",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "order_event_burst_replay": {
      "description": "Overloads Kafka queue while simultaneously introducing a consumer side delay leading to a lag spike",
      "state": "ENABLED",
      "variants": {
        "on": 100,
        "off": 0
      },
      "defaultVariant": "off"
    },
    "cart_storage_fallback": {
      "description": "Fail cart service",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "payment_provider_decline_rate": {
      "description": "Fail payment service charge requests n%",
      "state": "ENABLED",
      "variants": {
        "100%": 1,
        "90%": 0.95,
        "75%": 0.75,
        "50%": 0.5,
        "25%": 0.25,
        "10%": 0.1,
        "off": 0
      },
      "defaultVariant": "off"
    },
    "payment_routing_override": {
      "description": "Payment service is unavailable",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "homepage_traffic_burst": {
      "description": "Flood the frontend with a large amount of requests.",
      "state": "ENABLED",
      "variants": {
        "on": 100,
        "off": 0
      },
      "defaultVariant": "off"
    },
    "product_image_delay_ms": {
      "description": "slow loading images in the frontend",
      "state": "ENABLED",
      "variants": {
        "10sec": 10000,
        "5sec": 5000,
        "off": 0
      },
      "defaultVariant": "off"
    },
    "cart_startup_probe_override": {
      "description": "readiness probe failure for cart service",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "email_template_expansion_factor": {
      "description": "Memory leak in the email service.",
      "state": "ENABLED",
      "variants": {
        "off": 0,
        "1x": 1,
        "10x": 10,
        "100x": 100,
        "1000x": 1000,
        "10000x": 10000
      },
      "defaultVariant": "off"
    }
  }
}
